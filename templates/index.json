        "custom_liquid_3ttgpY": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "<div class=\"lb-wrap\">\n  <div class=\"lb-head\">\n    <span class=\"lb-ico\"><svg width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#B88B59\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/></svg></span>\n    <strong>Pourquoi la litière Zhanimo ?</strong>\n  </div>\n  <ul class=\"lb-list\">\n    <li><span class=\"lb-dot\">✔</span> Nettoyage <strong>automatique</strong> après chaque passage</li>\n    <li><span class=\"lb-dot\">✔</span> <strong>Zéro odeur</strong> — bac hermétique + charbon actif</li>\n    <li><span class=\"lb-dot\">✔</span> <strong>Suivi santé</strong> & alertes via appli</li>\n    <li><span class=\"lb-dot\">✔</span> Moteur <strong>silencieux</strong> — moins de 45 dB</li>\n  </ul>\n  <div class=\"lb-foot\">\n    <span class=\"lb-tag\">✓ Remboursé 30 jours</span>\n    <span class=\"lb-tag\">✓ Garantie 2 ans</span>\n  </div>\n<style>\n  .lb-wrap {\n    margin-top: 14px;\n    padding: 14px 14px 12px;\n    border-radius: 12px;\n    background: #FDF8F3;\n    border: 1px solid #E8D5BC;\n    position: relative;\n    overflow: hidden;\n  }\n  .lb-wrap::before {\n    content: '';\n    position: absolute;\n    top: 0; left: 0;\n    width: 4px; height: 100%;\n    background: linear-gradient(180deg, #D4AF7A, #B88B59);\n    border-radius: 12px 0 0 12px;\n  }\n  .lb-head {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    margin-bottom: 12px;\n    padding-bottom: 10px;\n    border-bottom: 1px solid #EDE0CE;\n    font-size: 13px;\n    font-weight: 700;\n    color: #1A1714;\n  }\n  .lb-ico {\n    width: 28px; height: 28px; min-width: 28px;\n    background: #fff;\n    border: 1px solid #E8D5BC;\n    border-radius: 7px;\n    display: flex; align-items: center; justify-content: center;\n  }\n  .lb-list {\n    margin: 0; padding: 0;\n    list-style: none;\n    display: grid;\n    gap: 8px;\n  }\n  .lb-list li {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    font-size: 13px;\n    color: #2F3A44;\n    line-height: 1.3;\n  }\n  .lb-list li strong { color: #1A1714; font-weight: 600; }\n  .lb-dot {\n    flex-shrink: 0;\n    width: 18px; height: 18px;\n    background: #B88B59;\n    border-radius: 50%;\n    color: #fff;\n    font-size: 9px;\n    font-weight: 900;\n    display: flex; align-items: center; justify-content: center;\n  }\n  .lb-foot {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 6px;\n    margin-top: 12px;\n    padding-top: 10px;\n    border-top: 1px solid #EDE0CE;\n  }\n  .lb-tag {\n    font-size: 11px;\n    font-weight: 600;\n    color: #B88B59;\n    background: #fff;\n    border: 1px solid #E8D5BC;\n    border-radius: 20px;\n    padding: 3px 10px;\n  }\n</style>\n</div>"
