n-bottom: 24px;\n}\n\n.zh-tiktok-title {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  font-size: 20px;\n  font-weight: 700;\n  color: #1A1A18;\n}\n\n.zh-tiktok-title svg {\n  color: #B88B59;\n}\n\n.zh-tiktok-cta {\n  display: inline-flex;\n  align-items: center;\n  gap: 6px;\n  font-size: 13px;\n  font-weight: 600;\n  color: #B88B59;\n  text-decoration: none;\n  border: 1px solid #E8D5BC;\n  padding: 7px 14px;\n  border-radius: 20px;\n  background: #FDF8F3;\n  transition: background 0.2s, box-shadow 0.2s;\n}\n\n.zh-tiktok-cta:hover {\n  background: #F3E8D8;\n  box-shadow: 0 2px 10px rgba(184,139,89,0.15);\n}\n\n.zh-tiktok-grid {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  gap: 16px;\n}\n\n.zh-tiktok-card {\n  position: relative;\n  border-radius: 16px;\n  overflow: hidden;\n  aspect-ratio: 9/16;\n  cursor: pointer;\n  background: #111;\n  box-shadow: 0 8px 30px rgba(0,0,0,0.12);\n  transition: transform 0.3s, box-shadow 0.3s;\n}\n\n.zh-tiktok-card:hover {\n  transform: translateY(-4px);\n  box-shadow: 0 16px 40px rgba(184,139,89,0.2);\n}\n\n.zh-vid {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  display: block;\n}\n\n.zh-vid-overlay {\n  position: absolute;\n  inset: 0;\n  background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, transparent 40%);\n  pointer-events: none;\n}\n\n.zh-vid-badge {\n  position: absolute;\n  bottom: 14px;\n  left: 12px;\n  display: flex;\n  align-items: center;\n  gap: 5px;\n  background: rgba(0,0,0,0.5);\n  backdrop-filter: blur(6px);\n  color: #fff;\n  font-size: 11px;\n  font-weight: 600;\n  padding: 5px 10px;\n  border-radius: 20px;\n  letter-spacing: 0.04em;\n}\n\n.zh-sound-btn {\n  position: absolute;\n  bottom: 14px;\n  right: 12px;\n  width: 32px;\n  height: 32px;\n  border-radius: 50%;\n  background: rgba(0,0,0,0.5);\n  backdrop-filter: blur(6px);\n  border: none;\n  cursor: pointer;\n  color: #fff;\n  display: grid;\n  place-items: center;\n  transition: background 0.2s;\n  z-index: 10;\n}\n\n.zh-sound-btn:hover {\n  background: rgba(184,139,89,0.8);\n}\n\n@media (max-width: 768px) {\n  .zh-tiktok-grid {\n    grid-template-columns: repeat(3, 1fr);\n    gap: 10px;\n  }\n\n  .zh-tiktok-title {\n    font-size: 16px;\n  }\n\n  .zh-tiktok-cta {\n    font-size: 11px;\n    padding: 6px 10px;\n  }\n}\n\n@media (max-width: 480px) {\n  .zh-tiktok-grid {\n    grid-template-columns: repeat(3, 1fr);\n    gap: 8px;\n  }\n\n  .zh-tiktok-section {\n    padding: 30px 12px;\n  }\n}\n</style>\n\n<script>\nfunction toggleSound(btn) {\n  var card = btn.closest('.zh-tiktok-card');\n  var video = card.querySelector('.zh-vid');\n  var isMuted = btn.getAttribute('data-muted') === 'true';\n\n  if (isMuted) {\n    video.muted = false;\n    btn.setAttribute('data-muted', 'false');\n    btn.querySelector('.icon-mute').style.display = 'none';\n    btn.querySelector('.icon-sound').style.display = 'block';\n  } else {\n    video.muted = true;\n    btn.setAttribute('data-muted', 'true');\n    btn.querySelector('.icon-mute').style.display = 'block';\n    btn.querySelector('.icon-sound').style.display = 'none';\n  }\n}\n</script>"
