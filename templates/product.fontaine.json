label {\n    display: inline-block;\n    font-size: 11px;\n    font-weight: 600;\n    letter-spacing: 0.12em;\n    text-transform: uppercase;\n    color: #B88D5A;\n    margin-bottom: 10px;\n  }\n  .benefits-header h2 {\n    font-family: 'DM Serif Display', serif;\n    font-size: 28px;\n    font-weight: 400;\n    line-height: 1.2;\n    margin-bottom: 10px;\n    color: #1A1714;\n  }\n  .benefits-header p {\n    color: #6B6560;\n    font-size: 14px;\n    line-height: 1.5;\n  }\n  .benefits-grid {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 12px;\n    max-width: 600px;\n    margin: 0 auto;\n  }\n  .benefit-card {\n    background: #F5EEE4;\n    border-radius: 10px;\n    padding: 18px 16px;\n    border-top: 3px solid #B88D5A;\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n  }\n  .benefit-top {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n  }\n  .benefit-icon {\n    width: 36px;\n    height: 36px;\n    min-width: 36px;\n    background: #B88D5A;\n    border-radius: 7px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n  .benefit-icon svg {\n    width: 18px;\n    height: 18px;\n    stroke: white;\n    fill: none;\n    stroke-width: 2;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n  .benefit-card h3 {\n    font-family: 'DM Serif Display', serif;\n    font-size: 15px;\n    font-weight: 400;\n    color: #1A1714;\n    line-height: 1.25;\n    margin: 0;\n  }\n  .benefit-card p {\n    font-size: 12px;\n    color: #6B6560;\n    line-height: 1.55;\n    margin: 0;\n  }\n\n  @media (min-width: 600px) {\n    .benefits { padding: 70px 40px; }\n    .benefits-header h2 { font-size: 36px; }\n    .benefits-grid { grid-template-columns: repeat(3, 1fr); gap: 20px; }\n    .benefit-card { padding: 26px 22px; }\n    .benefit-icon { width: 44px; height: 44px; min-width: 44px; }\n    .benefit-icon svg { width: 22px; height: 22px; }\n    .benefit-card h3 { font-size: 18px; }\n    .benefit-card p { font-size: 13px; }\n  }\n<\/style>\n\n<link href=\"https:\/\/fonts.googleapis.com\/css2?family=DM+Serif+Display&family=DM+Sans:wght@400;600&display=swap\" rel=\"stylesheet\">\n\n<section class=\"benefits\">\n  <div class=\"benefits-header\">\n    <span class=\"benefits-section-label\">Pourquoi notre fontaine<\/span>\n    <h2>Une hydratation sans effort<\/h2>\n    <p>Une eau filtrée, fraîche et circulante — pour que votre chat boive plus, naturellement.<\/p>\n  <\/div>\n\n  <div class=\"benefits-grid\">\n\n    <div class=\"benefit-card\">\n      <div class=\"benefit-top\">\n        <div class=\"benefit-icon\">\n          <svg viewbox=\"0 0 24 24\"><path d=\"M12 2C6 2 2 7 2 12a10 10 0 0020 0c0-5-4-10-10-10z\"><\/path><path d=\"M12 6v6l4 2\"><\/path><\/svg>\n        <\/div>\n        <h3>Flux continu 24h\/24<\/h3>\n      <\/div>\n      <p>L'eau circule en permanence — les chats boivent 2× plus avec une eau en mouvement.<\/p>\n    <\/div>\n\n    <div class=\"benefit-card\">\n      <div class=\"benefit-top\">\n        <div class=\"benefit-icon\">\n          <svg viewbox=\"0 0 24 24\"><path d=\"M12 2l3 7h7l-5.5 4 2 7L12 16l-6.5 4 2-7L2 9h7z\"><\/path><\/svg>\n        <\/div>\n        <h3>Triple filtration<\/h3>\n      <\/div>\n      <p>Charbon actif, mousse et filtre à ions — poils, calcaire et bactéries éliminés.<\/p>\n    <\/div>\n\n    <div class=\"benefit-card\">\n      <div class=\"benefit-top\">\n        <div class=\"benefit-icon\">\n          <svg viewbox=\"0 0 24 24\"><rect x=\"5\" y=\"2\" width=\"14\" height=\"20\" rx=\"2\" ry=\"2\"><\/rect><line x1=\"12\" y1=\"18\" x2=\"12.01\" y2=\"18\"><\/line><\/svg>\n        <\/div>\n        <h3>Pilotage via appli<\/h3>\n      <\/div>\n      <p>Suivi de consommation, débit ajustable et alertes en temps réel. iOS & Android.<\/p>\n    <\/div>\n\n    <div class=\"benefit-card\">\n      <div class=\"benefit-top\">\n        <div class=\"benefit-icon\">\n          <svg viewbox=\"0 0 24 24\"><path d=\"M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 012.12 4.18 2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z\"><\/path><\/svg>\n        <\/div>\n        <h3>Alerte niveau bas<\/h3>\n      <\/div>\n      <p>Capteur intégré — la pompe s'arrête et vous recevez une notification dès que le réservoir est vide.<\/p>\n    <\/div>\n\n    <div class=\"benefit-card\">\n      <div class=\"benefit-top\">\n        <div class=\"benefit-icon\">\n          <svg viewbox=\"0 0 24 24\"><polygon points=\"11 5 6 9 2 9 2 15 6 15 11 19 11 5\"><\/polygon><path d=\"M15.54 8.46a5 5 0 010 7.07\"><\/path><\/svg>\n        <\/div>\n        <h3>Ultra silencieuse<\/h3>\n      <\/div>\n      <p>Pompe brushless à moins de 40 dB — fonctionne toute la nuit sans vous déranger.<\/p>\n    <\/div>\n\n    <div class=\"benefit-card\">\n      <div class=\"benefit-top\">\n        <div class=\"benefit-icon\">\n          <svg viewbox=\"0 0 24 24\"><polyline points=\"20 12 20 22 4 22 4 12\"><\/polyline><rect x=\"2\" y=\"7\" width=\"20\" height=\"5\"><\/rect><line x1=\"12\" y1=\"22\" x2=\"12\" y2=\"7\"><\/line><path d=\"M12 7H7.5a2.5 2.5 0 010-5C11 2 12 7 12 7z\"><\/path><path d=\"M12 7h4.5a2.5 2.5 0 000-5C13 2 12 7 12 7z\"><\/path><\/svg>\n        <\/div>\n        <h3>Livraison offerte<\/h3>\n      <\/div>\n      <p>Expédié en 24–48h. Retour gratuit sous 30 jours.<\/p>\n    <\/div>\n\n  <\/div>\n<\/section>"}},"sp_custom_html_KPziUk":{"type":"sp-custom-html","name":"nous vs eux ","settings":{"title":"","custom_html":"<link href=\"https:\/\/fonts.googleapis.com\/css2?family=Sora:wght@700;800&family=DM+Sans:wght@400;500&display=swap\" rel=\"stylesheet\">\n\n<style>\n  #zh-cmp {\n    padding: 40px 16px 48px;\n    background: #fff;\n    font-family: 'DM Sans', sans-serif;\n    box-sizing: border-box;\n  }\n  #zh-cmp * { box-sizing: border-box; }\n\n  #zh-cmp .zh-intro { margin-bottom: 