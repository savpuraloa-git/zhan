rder-radius: 0 0 14px 0; }\n\n  .zh-yes {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    width: 26px; height: 26px;\n    background: #B88D5A;\n    border-radius: 50%;\n    color: #fff;\n    font-size: 13px;\n    font-weight: 700;\n  }\n  .zh-no    { color: #c9bdb0; font-size: 20px; font-weight: 700; }\n  .zh-emoji { font-size: 18px; }\n<\/style>\n\n<div id=\"zh-cmp\">\n\n  <div class=\"zh-intro\">\n    <h2>Avec notre fontaine, qu'est-ce qui change vraiment ?<\/h2>\n    <p>Découvrez ce que la fontaine connectée Zhanimo apporte face à un bol d'eau classique.<\/p>\n  <\/div>\n\n  <table>\n    <thead>\n      <tr>\n        <th class=\"zh-th-label\"><\/th>\n        <th class=\"zh-th-brand\">Fontaine Zhanimo<\/th>\n        <th class=\"zh-th-other\">Bol classique<\/th>\n      <\/tr>\n    <\/thead>\n    <tbody>\n      <tr>\n        <td class=\"zh-label-cell\">Eau filtrée en continu<\/td>\n        <td class=\"zh-brand-cell\"><span class=\"zh-yes\">✓<\/span><\/td>\n        <td class=\"zh-other-cell\"><span class=\"zh-no\">✕<\/span><\/td>\n      <\/tr>\n      <tr>\n        <td class=\"zh-label-cell\">Circulation de l'eau<\/td>\n        <td class=\"zh-brand-cell\"><span class=\"zh-yes\">✓<\/span><\/td>\n        <td class=\"zh-other-cell\"><span class=\"zh-no\">✕<\/span><\/td>\n      <\/tr>\n      <tr>\n        <td class=\"zh-label-cell\">Suivi consommation via app<\/td>\n        <td class=\"zh-brand-cell\"><span class=\"zh-yes\">✓<\/span><\/td>\n        <td class=\"zh-other-cell\"><span class=\"zh-no\">✕<\/span><\/td>\n      <\/tr>\n      <tr>\n        <td class=\"zh-label-cell\">Alerte niveau bas<\/td>\n        <td class=\"zh-brand-cell\"><span class=\"zh-yes\">✓<\/span><\/td>\n        <td class=\"zh-other-cell\"><span class=\"zh-no\">✕<\/span><\/td>\n      <\/tr>\n      <tr>\n        <td class=\"zh-label-cell\">Élimination bactéries<\/td>\n        <td class=\"zh-brand-cell\"><span class=\"zh-yes\">✓<\/span><\/td>\n        <td class=\"zh-other-cell\"><span class=\"zh-no\">✕<\/span><\/td>\n      <\/tr>\n      <tr>\n        <td class=\"zh-label-cell\">Niveau sonore<\/td>\n        <td class=\"zh-brand-cell\"><span class=\"zh-emoji\">🔇<\/span><\/td>\n        <td class=\"zh-other-cell\"><span class=\"zh-emoji\">💧<\/span><\/td>\n      <\/tr>\n    <\/tbody>\n  <\/table>\n\n<\/div>"}},"eba88da5-80ac-47fc-aa75-997cfe7b2e59":{"type":"image-slider","blocks":{"template--21507361800487__eba88da5-80ac-47fc-aa75-997cfe7b2e59-image_slide-1":{"type":"image_slide","settings":{"image":"shopify:\/\/shop_images\/Fontaine_a_eau_en_ceramique_pour_animaux2.webp","link":"","description":"","desc_alignment":"center","desc_color_scheme":"background-2"}},"template--21507361800487__eba88da5-80ac-47fc-aa75-997cfe7b2e59-image_slide-2":{"type":"image_slide","settings":{"image":"shopify:\/\/shop_images\/Fontaine_a_eau_chat_inox4.webp","link":"","description":"","desc_alignment":"center","desc_color_scheme":"background-2"}},"template--21507361800487__eba88da5-80ac-47fc-aa75-997cfe7b2e59-image_slide-3":{"type":"image_slide","settings":{"image":"shopify:\/\/shop_images\/Fontaine_a_eau.webp","link":"","description":"","desc_alignment":"center","desc_color_scheme":"background-2"}},"template--21507361800487__eba88da5-80ac-47fc-aa75-997cfe7b2e59-image_slide-4":{"type":"image_slide","settings":{"image":"shopify:\/\/shop_images\/8e0aa140-5b89-43df-a6ea-d6bb11b94c19.png","link":"","description":"","desc_alignment":"center","desc_color_scheme":"background-2"}}},"block_order":["template--21507361800487__eba88da5-80ac-47fc-aa75-997cfe7b2e59-image_slide-1","template--21507361800487__eba88da5-80ac-47fc-aa75-997cfe7b2e59-image_slide-2","template--21507361800487__eba88da5-80ac-47fc-aa75-997cfe7b2e59-image_slide-3","template--21507361800487__eba88da5-80ac-47fc-aa75-997cfe7b2e59-image_slide-4"],"settings":{"display_id":false,"visibility":"always-display","title":"","title_highlight_color":"#6d388b","heading_size":"h1","color_scheme":"background-1","