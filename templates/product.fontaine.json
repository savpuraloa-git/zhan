d","background_color":"background-1","custom_background_color":"#ffffff","padding_top":0,"padding_bottom":0}},"4fc05ee5-1c30-4863-b88f-81cb6fa7c41a":{"type":"icons-with-content","blocks":{"template--21507361800487__4fc05ee5-1c30-4863-b88f-81cb6fa7c41a-icon-1":{"type":"icon","settings":{"icon":"check_circle","filled_icon":false,"title":"Déverrouillage par empreinte","text":"<p>Accédez à votre maison en une seconde grâce à la reconnaissance d’empreinte digitale rapide et sécurisée.<\/p>"}},"template--21507361800487__4fc05ee5-1c30-4863-b88f-81cb6fa7c41a-icon-2":{"type":"icon","settings":{"icon":"check_circle","filled_icon":false,"title":"Accès sans clé","text":"<p>Plus besoin de transporter vos clés. Ouvrez votre porte facilement avec votre empreinte digitale.<\/p>"}},"template--21507361800487__4fc05ee5-1c30-4863-b88f-81cb6fa7c41a-icon-3":{"type":"icon","settings":{"icon":"check_circle","filled_icon":false,"title":"Installation rapide","text":"<p>Compatible avec la plupart des portes standards et simple à installer en quelques minutes<\/p>"}},"template--21507361800487__4fc05ee5-1c30-4863-b88f-81cb6fa7c41a-heading-1":{"type":"heading","settings":{"title":"Sécurité intelligente pour votre maison","title_highlight_color":"#6d388b","heading_size":"h1"}},"template--21507361800487__4fc05ee5-1c30-4863-b88f-81cb6fa7c41a-text-1":{"type":"text","settings":{"text":"<p>Découvrez la serrure connectée Secureo, conçue pour simplifier votre quotidien tout en protégeant votre domicile. Grâce à la technologie biométrique avancée, votre porte se déverrouille instantanément avec votre empreinte digitale.<\/p>","text_style":"body"}}},"block_order":["template--21507361800487__4fc05ee5-1c30-4863-b88f-81cb6fa7c41a-icon-1","template--21507361800487__4fc05ee5-1c30-4863-b88f-81cb6fa7c41a-icon-2","template--21507361800487__4fc05ee5-1c30-4863-b88f-81cb6fa7c41a-icon-3","template--21507361800487__4fc05ee5-1c30-4863-b88f-81cb6fa7c41a-heading-1","template--21507361800487__4fc05ee5-1c30-4863-b88f-81cb6fa7c41a-text-1"],"disabled":true,"settings":{"display_id":false,"visibility":"always-display","color_scheme":"custom","icon_size":"m","icon_position":"next-to-title","icon_color":"background-2","icon_heading_size":"h3","icon_text_alignment":"left","icons_desktop_layout":"1-column","icons_mobile_layout":"1-column","desktop_content_alignment":"left","layout":"image_first","mobile_layout":"text_first","hide_content_on_mobile":false,"padding_top":36,"padding_bottom":36,"custom_colors_background":"#2563eb","custom_gradient_background":"","custom_colors_text":"#ffffff","custom_colors_solid_button_background":"#dd1d1d","custom_colors_solid_button_text":"#ffffff","custom_colors_outline_button":"#dd1d1d"}},"section_divider_dQTTMC":{"type":"section-divider","settings":{"visibility":"always-display","shape":"sharp_2","flip_horizontal":true,"flip_vertical":true,"shape_color":"accent-1","custom_shape_color":"#dd1d1d","background_color":"background-1","custom_background_color":"#ffffff","padding_top":0,"padding_bottom":0}},"sp_custom_html_bXVkWC":{"type":"sp-custom-html","name":"FAQ Fontaine","settings":{"title":"","custom_html":"<div class=\"faq-section\">\n  <div class=\"faq-container\">\n\n    <span class=\"faq-label\">Support client<\/span>\n    <h2 class=\"faq-title\">Questions Fréquentes<\/h2>\n\n    <div class=\"faq-list\">\n\n      <div class=\"faq-item\">\n        <button class=\"faq-question\" type=\"button\" aria-expanded=\"false\">\n          <span>Comment fonctionne la fontaine à eau connectée ?<\/span>\n          <span class=\"faq-icon-wrap\">\n            <svg width=\"14\" height=\"14\" viewbox=\"0 0 24 24\" fill=\"none\"><path d=\"M6 9L12 15L18 9\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><\/path><\/svg>\n          <\/span>\n        <\/button>\n        <div class=\"faq-answer\">\n          <div class=\"faq-answer-content\">\n            <p>La fontaine filtre l'eau en continu grâce à un système de triple filtration (charbon actif, mousse et filtre à ions). Le flux est ajustable via l'application — votre chat a toujours accès à une eau fraîche et purifiée, 24h\/24.<\/p>\n          <\/div>\n        <\/div>\n      <\/div>\n\n      <div class=\"faq-item\">\n        <button class=\"faq-question\" type=\"button\" aria-expanded=\"false\">\n          <span>À quelle fréquence changer le filtre ?<\/span>\n          <span class=\"faq-icon-wrap\">\n            <svg width=\"14\" height=\"14\" viewbox=\"0 0 24 24\" fill=\"none\"><path d=\"M6 9L12 15L18 9\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><\/path><\/svg>\n          <\/span>\n        <\/button>\n        <div class=\"faq-answer\">\n          <div class=\"faq-answer-content\">\n            <p>Environ toutes les 4 à 6 semaines selon l'utilisation. L'application vous envoie une notification automatique quand le filtre doit être remplacé — plus besoin d'y penser.<\/p>\n          <\/div>\n        <\/div>\n      <\/div>\n\n      <div class=\"faq-item\">\n        <button class=\"faq-question\" type=\"button\" aria-expanded=\"false\">\n          <span>La pompe est-elle silencieuse ?<\/span>\n          <span class=\"faq-icon-wrap\">\n            <svg width=\"14\" height=\"14\" viewbox=\"0 0 24 24\" fill=\"none\"><path d=\"M6 9L12 15L18 9\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><\/path><\/svg>\n          <\/span>\n        <\/button>\n        <div class=\"faq-answer\">\n          <div class=\"faq-answer-content\">\n            <p>Oui. La pompe brushless intégrée tourne à moins de 40 dB — soit le niveau d'une bibliothèque. Elle peut fonctionner toute la nuit sans vous déranger ni perturber votre chat.<\/p>\n          <\/div>\n        <\/div>\n      <\/div>\n\n      <div class=\"faq-item\">\n        <button class=\"faq-question\" type=\"button\" aria-expanded=\"false\">\n          <span>Que se passe-t-il si le niveau d'eau est trop bas ?<\/span>\n          <span class=\"faq-icon-wrap\">\n            <svg width=\"14\" height=\"14\" viewbox=\"0 0 24 24\" fill=\"none\"><path d=\"M6 9L12 15L18 9\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><\/path><\/svg>\n          <\/span>\n        <\/button>\n        <div class=\"faq-answer\">\n          <div class=\"faq-answer-content\">\n            <p>Le capteur de niveau détecte automatiquement quand le réservoir descend sous le seuil minimal. La pompe s'arrête pour se protéger et vous recevez une alerte push sur votre téléphone immédiatement.<\/p>\n          <\/div>\n        <\/div>\n      <\/div>\n\n      <div class=\"faq-item\">\n        <button class=\"faq-question\" type=\"button\" aria-expanded=\"false\">\n          <span>L'application est-elle gratuite et compatible avec mon téléphone ?<\/span>\n          <span class=\"faq-icon-wrap\">\n            <svg width=\"14\" height=\"14\" viewbox=\"0 0 24 24\" fill=\"none\"><path d=\"M6 9L12 15L18 9\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><\/path><\/svg>\n          <\/span>\n        <\/button>\n        <div class=\"faq-answer\">\n          <div class=\"faq-answer-content\">\n            <p>L'application est 100% gratuite, disponible sur iOS et Android. Elle vous permet de suivre la consommation d'eau de votre chat, ajuster le débit, programmer des modes et recevoir toutes les alertes en temps réel.<\/p>\n          <\/div>\n        <\/div>\n      <\/div>\n\n      <div class=\"faq-item\">\n        <button class=\"faq-question\" type=\"button\" aria-expanded=\"false\">\n          <span>Comment entretenir et nettoyer la fontaine ?<\/span>\n          <span class=\"faq-icon-wrap\">\n            <svg width=\"14\" height=\"14\" viewbox=\"0 0 24 24\" fill=\"none\"><path d=\"M6 9L12 15L18 9\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><\/path><\/svg>\n          <\/span>\n        <\/button>\n        <div class=\"faq-answer\">\n          <div class=\"faq-answer-content\">\n            <p>Toutes les pièces (réservoir, bac, couvercle) sont démontables et compatibles lave-vaisselle. Un nettoyage complet toutes les 2 semaines suffit. La pompe se nettoie à la brosse sous l'eau courante.<\/p>\n          <\/div>\n        <\/div>\n      <\/div>\n\n      <div class=\"faq-item\">\n        <button class=\"faq-question\" type=\"button\" aria-expanded=\"false\">\n          <span>Livrez-vous partout en France ?<\/span>\n          <span class=\"faq-icon-wrap\">\n            <svg width=\"14\" height=\"14\" viewbox=\"0 0 24 24\" fill=\"none\"><path d=\"M6 9L12 15L18 9\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><\/path><\/svg>\n          <\/span>\n        <\/button>\n        <div class=\"faq-answer\">\n          <div class=\"faq-answer-content\">\n            <p>Oui, toute la France métropolitaine et la Corse. Livraison gratuite en 6–12 jours ouvrés. Retour gratuit sous 30 jours si vous n'êtes pas satisfait.<\/p>\n          <\/div>\n        <\/div>\n      <\/div>\n\n    <\/div>\n  <\/div>\n<\/div>\n\n<style>\n.faq-section {\n  padding: 80px 20px;\n  background: #ffffff;\n}\n\n.faq-container {\n  max-width: 780px;\n  margin: 0 auto;\n  text-align: center;\n}\n\n.faq-label {\n  display: inline-block;\n  font-size: 11px;\n  font-weight: 600;\n  letter-spacing: 0.12em;\n  text-transform: uppercase;\n  color: #B88B59;\n  background: #F3E8D8;\n  border: 1px solid #E8D5BC;\n  padding: 4px 12px;\n  border-radius: 20px;\n  margin-bottom: 14px;\n}\n\n.faq-title {\n  font-size: 32px;\n  font-weight: 700;\n  color: #1A1A18;\n  margin-bottom: 40px;\n  line-height: 1.2;\n}\n\n.faq-title::after {\n  content: '';\n  display: block;\n  width: 40px;\n  height: 3px;\n  background: #B88B59;\n  border-radius: 2px;\n  margin: 12px auto 0;\n}\n\n.faq-list {\n  display: flex;\n  flex-direction: column;\n  gap: 10px;\n  text-align: left;\n}\n\n.faq-item {\n  background: #FDF8F3;\n  border: 1px solid #E8D5BC;\n  border-radius: 12px;\n  overflow: hidden;\n  transition: box-shadow 0.2s, border-color 0.2s;\n}\n\n.faq-item:hover {\n  border-color: #B88B59;\n  box-shadow: 0 4px 16px rgba(184,139,89,0.1);\n}\n\n.faq-item.active {\n  background: #ffffff;\n  border-color: #B88B59;\n  box-shadow: 0 4px 20px rgba(184,139,89,0.15);\n}\n\n.faq-question {\n  width: 100%;\n  padding: 18px 20px;\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  gap: 16px;\n  background: none;\n  border: none;\n  cursor: pointer;\n  text-align: left;\n  font-size: 15px;\n  font-weight: 600;\n  color: #1A1A18;\n  transition: color 0.2s;\n}\n\n.faq-icon-wrap {\n  flex-shrink: 0;\n  width: 28px;\n  height: 28px;\n  border-radius: 50%;\n  background: #F3E8D8;\n  border: 1px solid #E8D5BC;\n  display: grid;\n  place-items: center;\n  color: #B88B59;\n  transition: transform 0.3s, background 0.2s;\n}\n\n.faq-item.active .faq-icon-wrap {\n  transform: rotate(180deg);\n  background: #B88B59;\n  color: #fff;\n  border-color: #B88B59;\n}\n\n.faq-answer {\n  max-height: 0;\n  overflow: hidden;\n  transition: max-height 0.4s ease;\n}\n\n.faq-item.active .faq-answer {\n  max-height: 400px;\n}\n\n.faq-answer-content {\n  padding: 0 20px 18px;\n  border-top: 1px solid #F0E6D8;\n  margin: 0 20px;\n}\n\n.faq-answer-content p {\n  margin: 14px 0 0;\n  font-size: 14px;\n  line-height: 1.7;\n  color: #666;\n}\n\n@media (max-width: 768px) {\n  .faq-section { padding: 40px 12px; }\n  .faq-title { font-size: 24px; margin-bottom: 28px; }\n  .faq-question { padding: 14px 16px; font-size: 14px; }\n  .faq-answer-content { margin: 0 16px; padding: 0 0 14px; }\n  .faq-answer-content p { font-size: 13px; }\n}\n<\/style>\n\n<script>\n(function() {\n  var faqItems = document.querySelectorAll('.faq-item');\n  faqItems.forEach(function(item) {\n    var question = item.querySelector('.faq-question');\n    var answer = item.querySelector('.faq-answer');\n    question.addEventListener('click', function() {\n      var isActive = item.classList.contains('active');\n      faqItems.forEach(function(other) {\n        if (other !== item) {\n          other.classList.remove('active');\n          other.querySelector('.faq-answer').style.maxHeight = null;\n          other.querySelector('.faq-question').setAttribute('aria-expanded', 'false');\n        }\n      });\n      if (isActive) {\n        item.classList.remove('active');\n        answer.style.maxHeight = null;\n        question.setAttribute('aria-expanded', 'false');\n      } else {\n        item.classList.add('active');\n        answer.style.maxHeight = answer.scrollHeight + 'px';\n        question.setAttribute('aria-expanded', 'true');\n      }\n    });\n  });\n})();\n<\/script>"}}},"order":["main","sp_custom_html_jrCPCm","sp_custom_html_KPziUk","eba88da5-80ac-47fc-aa75-997cfe7b2e59","related-products","8beb6911-28c6-482c-976a-e5421ad3e8df","b321ab88-2b59-4dba-bade-54885c874ca5","4fc05ee5-1c30-4863-b88f-81cb6fa7c41a","section_divider_dQTTMC","sp_custom_html_bXVkWC"]}